# SECTION 5: SUCCESS PATTERNS (ALWAYS USE)

## ✅ Keep-Warm Function

```python
@app.function(schedule=modal.Cron("*/5 * * * *"))
def keep_warm():
    """Prevents cold starts - 10x faster"""
    return {"status": "warm", "timestamp": datetime.now().isoformat()}
```

## ✅ Error Handling

```python
def safe_operation(func):
    def wrapper(*args, **kwargs):
        try:
            result = func(*args, **kwargs)
            print(f"✅ {func.__name__}: Success")
            return result
        except Exception as e:
            print(f"❌ {func.__name__}: {str(e)}")
            log_error_to_db(func.__name__, str(e))
            raise
    return wrapper
```

## ✅ Rate Limiting

```python
import time
last_call = {}
MIN_DELAY = 0.6  # 100 calls/min

def rate_limit(api_name):
    def decorator(func):
        def wrapper(*args, **kwargs):
            now = time.time()
            if api_name in last_call:
                elapsed = now - last_call[api_name]
                if elapsed < MIN_DELAY:
                    time.sleep(MIN_DELAY - elapsed)
            result = func(*args, **kwargs)
            last_call[api_name] = time.time()
            return result
        return wrapper
    return decorator
```

